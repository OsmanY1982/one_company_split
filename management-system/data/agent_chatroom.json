  "chatroom": {
    "id": "one_company_internal_chatroom",
    "name": "一人公司内部聊天室",
    "description": "CEO 与固定数字员工之间的内部协作空间。董事长只管理 CEO，员工之间通过本聊天室接受 CEO 分配任务、汇报进展、讨论方案。",
    "rules": [
      "董事长只直接管理 CEO，不直接管理普通员工。",
      "CEO 负责任务拆解、员工分配、结果汇总和最终汇报。",
      "员工发言必须标明：员工名、职位、当前任务、结论或问题。",
      "员工不得越权替 CEO 或董事长做最终决策。",
      "涉及代码修改、发布、付款、合同、重要对外内容，必须先提交 CEO 确认。",
      "记忆员工负责把关键结论写入公司记忆。",
      "项目员工负责把任务写入任务板。",
      "测试员工负责在发布或交付前做质量检查。"
    ]
  },
